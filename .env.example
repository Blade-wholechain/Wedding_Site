# Copy to `.env` for the RSVP API. Vite reads gallery upload URL from here too.

# Mail on Render: outbound SMTP (587) is often blocked — use Resend (HTTPS) instead.
# https://resend.com — create API key, verify domain or use onboarding@resend.dev for tests.
RESEND_API_KEY=
# Optional; defaults to Resend sandbox sender if unset.
RESEND_FROM="RSVP bruiloft" <notifications@yourdomain.com>

# Gmail (RSVP, local dev): 2-Step Verification → App passwords — used when RESEND_API_KEY is unset
GMAIL_USER=doelsenwyb@gmail.com
GMAIL_APP_PASSWORD=

RSVP_NOTIFY_EMAIL=doelsenwyb@gmail.com
RSVP_SECRET=

PORT=3001

# Public URL of your Render RSVP API — no trailing slash. Same as GitHub Actions variable `RenderURL`.
# RenderURL=https://your-service.onrender.com

PhotoUpload=https://www.dropbox.com/request/...
